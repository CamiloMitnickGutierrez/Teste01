{
  "info": {
    "name": "MegaStore Global API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" }
  ],
  "item": [
    {
      "name": "Migration",
      "item": [
        {
          "name": "Load CSV",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/migration/load-csv", "host": ["{{base_url}}"], "path": ["api","migration","load-csv"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/products", "host": ["{{base_url}}"], "path": ["api","products"] }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/products/1", "host": ["{{base_url}}"], "path": ["api","products","1"] }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"sku\":\"NEW-001\",\"name\":\"New Product\",\"unit_price\":99.99,\"category_id\":1,\"supplier_id\":1}"
            },
            "url": { "raw": "{{base_url}}/api/products", "host": ["{{base_url}}"], "path": ["api","products"] }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Updated Product Name\",\"unit_price\":199.99}"
            },
            "url": { "raw": "{{base_url}}/api/products/1", "host": ["{{base_url}}"], "path": ["api","products","1"] }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/api/products/1", "host": ["{{base_url}}"], "path": ["api","products","1"] }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Supplier Analysis",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/reports/supplier-analysis", "host": ["{{base_url}}"], "path": ["api","reports","supplier-analysis"] }
          }
        },
        {
          "name": "Customer History",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/reports/customer-history/andres.lopez@gmail.com", "host": ["{{base_url}}"], "path": ["api","reports","customer-history","andres.lopez@gmail.com"] }
          }
        },
        {
          "name": "Top Products by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/reports/top-products/Electronics", "host": ["{{base_url}}"], "path": ["api","reports","top-products","Electronics"] }
          }
        }
      ]
    }
  ]
}
